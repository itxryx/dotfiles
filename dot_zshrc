# Paths
source ~/.config/zsh/path.zsh

# --- Environment Variables ---
export CLICOLOR=1
export EDITOR=vim
export FZF_TMUX=1
export HISTFILE=$HOME/.zsh_history
export HISTSIZE=1000000
export LANG=ja_JP.UTF-8
export SAVEHIST=1000000
export HOMEBREW_FORBIDDEN_FORMULAE="node python python3 pip npm pnpm yarn"

# Vi key bindings
bindkey -v

# Enable color support and completion
autoload -Uz colors
colors
autoload -Uz compinit
compinit

# --- Prompt ---
# Left: user@host cwd, Right: git branch info (set by precmd)
PROMPT='%F{117}%n@%m %~%f
%F{109}%D{%H:%M:%S}%f %F{109}%B❯%b%f '
RPROMPT='%F{109}${GIT_BRANCH_NAME}%f'

# --- Tool Initialization ---
eval "$(mise activate zsh)"
eval "$(zoxide init zsh)"
eval "$(sheldon source)"

# --- Options ---
setopt always_last_prompt
setopt auto_cd
setopt auto_list
setopt auto_menu
setopt auto_remove_slash
setopt extended_history
setopt hist_ignore_all_dups
setopt hist_reduce_blanks
setopt mark_dirs
setopt no_beep
setopt print_eight_bit
setopt prompt_subst
setopt share_history

# --- Abbreviations (zsh-abbr) ---
abbr -S g='git' &> /dev/null
abbr -S glog='glog = log --graph --stat --oneline --all --branches --tags --remotes --pretty=fuller --decorate=auto' &> /dev/null
abbr -S t='tig' &> /dev/null
abbr -S cpwd='pwd | pbcopy' &> /dev/null
abbr -S els='eza' &> /dev/null
abbr -S la='eza -a' &> /dev/null
abbr -S ll='eza -l' &> /dev/null
abbr -S lla='eza -la' &> /dev/null
abbr -S bcat='bat' &> /dev/null
abbr -S dk='docker' &> /dev/null
abbr -S dkc='docker compose' &> /dev/null
abbr -S history='history -i' &> /dev/null

# --- Prompt Hook ---
# Updates GIT_BRANCH_NAME with branch, modified count (*N), and untracked count (?N)
precmd () {
  BRANCH=$(git branch --show-current 2>/dev/null)
  if [ -n "$BRANCH" ]; then
    STATUS=$(git status --porcelain 2>/dev/null)
    ICON_BRANCH=''
    ICON_MOD='*'
    ICON_UNT='?'
    if [ -n "$STATUS" ]; then
      UNTRACKED_COUNT=$(printf '%s\n' "$STATUS" | grep -c '^??')
      MODIFIED_COUNT=$(printf '%s\n' "$STATUS" | grep -vc '^??')
      PARTS=""
      [ "$MODIFIED_COUNT" -gt 0 ] && PARTS="${PARTS}${ICON_MOD}${MODIFIED_COUNT} "
      [ "$UNTRACKED_COUNT" -gt 0 ] && PARTS="${PARTS}${ICON_UNT}${UNTRACKED_COUNT} "
      export GIT_BRANCH_NAME="${ICON_BRANCH} ${BRANCH} ${PARTS}"
    else
      export GIT_BRANCH_NAME="${ICON_BRANCH} ${BRANCH}"
    fi
  else
    export GIT_BRANCH_NAME=""
  fi
}

# Functions
source ~/.config/zsh/functions.zsh
