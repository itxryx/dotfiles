[user]
  name = komatsu ryo
  email = electrooculogram@gmail.com

[includeIf "gitdir:~/Works/"]
  path = ~/.gitconfig_work

[core]
  excludesfile = ~/.gitignore_global
  editor = vim
  pager = delta

[init]
  defaultBranch = main

[color]
  ui = auto

[status]
  showUntrackedFiles = all

[fetch]
  prune = true

[push]
  default = current

[pull]
  ff = only
  rebase = true

[rebase]
  autostash = true
  autosquash = true

[merge]
  ff = false
  conflictstyle = diff3

[diff]
  colorMoved = default

[interactive]
  diffFilter = delta --color-only

[delta]
  side-by-side = true
  line-numbers = true
  navigate = true
  light = false
